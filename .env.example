# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# CORS — set to your frontend origin in production
CORS_ORIGIN=*

# Optional API key (not enforced in MVP, reserved for future auth)
# API_KEY_OPTIONAL=your-secret-key-here

# Rate limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# Display character width heuristic (pixels)
CHAR_WIDTH_PX=4
CHAR_SPACING_PX=1

# Set to "true" to always include debug info in responses
DEBUG_ENABLED=false
